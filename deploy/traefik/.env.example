# Traefik stack environment variables
# Copy to .env and fill in values before running docker compose up -d

# Management domain — Traefik and Portainer are served as subdomains of this:
#   traefik.${MANAGEMENT_DOMAIN}   → Traefik dashboard (BasicAuth protected)
#   portainer.${MANAGEMENT_DOMAIN} → Portainer CE
# Example: ovbreadymix.co.za
MANAGEMENT_DOMAIN=

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=

# Traefik dashboard BasicAuth — format: "admin:<bcrypt-hash>"
# Generate: htpasswd -nB admin   OR use bootstrap.py (auto-generates)
TRAEFIK_ADMIN_AUTH=

# Timezone
TZ=Africa/Johannesburg
