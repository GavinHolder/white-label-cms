generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  username     String        @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole      @default(EDITOR)
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  apiKeys      ApiKey[]
  mediaAssets  MediaAsset[]
  pages        Page[]
  sections     Section[]
  volt3DAssets    Volt3DAsset[]
  voltElements   VoltElement[]
  contentEntries ContentEntry[]

  @@map("users")
}

model Page {
  id              String           @id @default(uuid())
  slug            String           @unique
  title           String
  type            PageType         @default(LANDING)
  metaDescription String?
  ogImage         String?
  status          PageStatus       @default(DRAFT)
  publishedAt     DateTime?
  publishedBy     String?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  canonicalUrl    String?
  metaKeywords    String?
  metaTitle       String?
  nofollow        Boolean          @default(false)
  noindex         Boolean          @default(false)
  ogDescription   String?
  ogTitle         String?
  enabled         Boolean          @default(true)
  formConfig      Json?
  navLabel        String?
  navOrder        Int?
  showOnNavbar    Boolean          @default(false)
  submissions     FormSubmission[]
  createdByUser   User             @relation(fields: [createdBy], references: [id])
  sections        Section[]

  @@index([slug])
  @@index([status])
  @@index([type])
  @@map("pages")
}

model FormSubmission {
  id        String   @id @default(uuid())
  pageId    String
  pageSlug  String
  data      Json
  userEmail String   @default("")
  status    String   @default("received")
  createdAt DateTime @default(now())
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([createdAt])
  @@map("form_submissions")
}

model Section {
  id                   String           @id @default(uuid())
  pageId               String
  type                 SectionType
  enabled              Boolean          @default(true)
  order                Float            @default(0)
  displayName          String?
  navLabel             String?
  paddingTop           Int              @default(80)
  paddingBottom        Int              @default(80)
  background           String           @default("white")
  banner               Json?
  content              Json             @default("{}")
  contentDraft         Json?
  triangleEnabled      Boolean          @default(false)
  triangleSide         String?
  triangleShape        String?          @default("classic")
  triangleHeight       Int?             @default(200)
  triangleTargetId     String?
  triangleGradientType String?          @default("solid")
  triangleColor1       String?          @default("#4ecdc4")
  triangleColor2       String?          @default("#6a82fb")
  triangleAlpha1       Int?             @default(100)
  triangleAlpha2       Int?             @default(100)
  triangleAngle        Int?             @default(45)
  triangleImageUrl     String?
  triangleImageSize    String?          @default("cover")
  triangleImagePos     String?          @default("center")
  triangleImageOpacity Int?             @default(100)
  hoverTextEnabled     Boolean          @default(false)
  hoverText            String?
  hoverTextStyle       Int?             @default(1)
  hoverFontSize        Int?             @default(18)
  hoverFontFamily      String?          @default("Arial")
  hoverAnimationType   String?          @default("slide")
  hoverAnimateBehind   Boolean          @default(true)
  hoverAlwaysShow      Boolean          @default(false)
  hoverOffsetX         Int?             @default(0)
  bgImageUrl           String?
  bgImageSize          String?          @default("cover")
  bgImagePosition      String?          @default("center")
  bgImageRepeat        String?          @default("no-repeat")
  bgImageOpacity       Int?             @default(100)
  bgParallax           Boolean          @default(false)
  createdBy            String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  lowerThird           Json?
  motionElements       Json?
  voltElementId        String?
  voltSlotMap          Json?
  paddingBottomMobile  Int?
  paddingTopMobile     Int?
  navOrder             Int?
  showOnNavbar         Boolean          @default(false)
  elements             CustomElement[]
  versions             SectionVersion[]
  createdByUser        User             @relation(fields: [createdBy], references: [id])
  page                 Page             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  voltElement          VoltElement?     @relation("SectionVolt", fields: [voltElementId], references: [id])

  @@index([pageId, order])
  @@index([enabled])
  @@map("sections")
}

model CustomElement {
  id               String          @id @default(uuid())
  sectionId        String
  parentId         String?
  type             ElementType
  order            Int
  content          Json?
  position         Json?
  spacing          Json
  styles           Json?
  responsiveStyles Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  parent           CustomElement?  @relation("ElementHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children         CustomElement[] @relation("ElementHierarchy")
  section          Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, order])
  @@index([parentId])
  @@map("custom_elements")
}

model MediaAsset {
  id             String   @id @default(uuid())
  filename       String
  originalName   String
  mimeType       String
  fileSize       Int
  width          Int?
  height         Int?
  url            String
  thumbnailUrl   String?
  altText        String?
  caption        String?
  tags           String[]
  uploadedBy     String
  usageCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  uploadedByUser User     @relation(fields: [uploadedBy], references: [id])

  @@index([mimeType])
  @@index([tags])
  @@map("media_assets")
}

model SectionVersion {
  id        String   @id @default(uuid())
  sectionId String
  version   Int
  config    Json
  createdBy String
  createdAt DateTime @default(now())
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, version])
  @@index([sectionId])
  @@map("section_versions")
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model OtpToken {
  id        String   @id @default(uuid())
  email     String
  code      String
  purpose   String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@map("otp_tokens")
}

model ClientFeature {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  enabled   Boolean  @default(false)
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("client_features")
}

model VoltElement {
  id           String      @id @default(cuid())
  name         String
  description  String?
  mood         String?
  elementType  String      @default("custom")
  isPublic     Boolean     @default(false)
  authorId     String
  layers       Json        @default("[]")
  slots        Json        @default("[]")
  states       Json        @default("[]")
  canvasWidth  Int         @default(800)
  canvasHeight Int         @default(500)
  has3D        Boolean     @default(false)
  tags         String[]
  isPaid       Boolean     @default(false)
  price        Float?
  downloads    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  thumbnail    String?
  flipCard     Json?
  sections     Section[]   @relation("SectionVolt")
  assets       VoltAsset[]
  author       User        @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([isPublic])
  @@map("volt_elements")
}

model VoltAsset {
  id        String      @id @default(cuid())
  voltId    String
  type      String
  filename  String
  url       String
  fileSize  Int
  metadata  Json?
  createdAt DateTime    @default(now())
  volt      VoltElement @relation(fields: [voltId], references: [id], onDelete: Cascade)

  @@index([voltId])
  @@map("volt_assets")
}

model ApiKey {
  id         String    @id @default(cuid())
  keyHash    String    @unique
  keyPrefix  String
  label      String
  userId     String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Volt3DAsset {
  id              String          @id @default(cuid())
  name            String
  authorId        String
  activeVersionId String?
  triggerConfig   Json?
  thumbnail       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  author          User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions        Volt3DVersion[]

  @@index([authorId])
  @@map("volt_3d_assets")
}

model Volt3DVersion {
  id          String      @id @default(cuid())
  assetId     String
  versionNum  Int
  glbPath     String
  blendPath   String?
  animClips   Json
  isConfirmed Boolean     @default(false)
  syncedAt    DateTime    @default(now())
  asset       Volt3DAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, versionNum])
  @@index([assetId])
  @@map("volt_3d_versions")
}

model CoverageMap {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  centerLat   Float            @default(-34.4187)
  centerLng   Float            @default(19.2345)
  defaultZoom Int              @default(10)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  labels      CoverageLabel[]
  regions     CoverageRegion[]

  @@map("coverage_maps")
}

model CoverageRegion {
  id          String      @id @default(cuid())
  mapId       String
  name        String
  polygon     Json        @default("[]")
  color       String      @default("#22c55e")
  opacity     Float       @default(0.4)
  strokeColor String      @default("#16a34a")
  strokeWidth Int         @default(2)
  description String?
  isActive    Boolean     @default(true)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  map         CoverageMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("coverage_regions")
}

model CoverageLabel {
  id         String      @id @default(cuid())
  mapId      String
  text       String
  lat        Float
  lng        Float
  fontSize   Int         @default(14)
  fontFamily String      @default("Arial")
  color      String      @default("#ffffff")
  bgColor    String?
  bold       Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  map        CoverageMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@index([mapId])
  @@map("coverage_labels")
}

model Project {
  id            String   @id @default(cuid())
  title         String
  location      String?
  description   String?
  coverImageUrl String?
  images        Json     @default("[]")
  completedDate String?
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("projects")
}

model SiteConfig {
  id             String   @id @default("singleton")
  companyName    String   @default("Your Company")
  tagline        String   @default("")
  logoUrl        String   @default("")
  faviconUrl     String   @default("")
  phone          String   @default("")
  email          String   @default("")
  address        String   @default("")
  city           String   @default("")
  postalCode     String   @default("")
  country        String   @default("")
  facebook       String   @default("")
  instagram      String   @default("")
  twitter        String   @default("")
  linkedin       String   @default("")
  youtube        String   @default("")
  copyrightText  String   @default("")
  showRegulatory Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  navbarStyle    String   @default("standard")
  tiktok         String   @default("")

  @@map("site_config")
}

enum UserRole {
  SUPER_ADMIN
  PUBLISHER
  EDITOR
  VIEWER
}

enum PageType {
  LANDING
  TAB_PAGE
  FULL_PAGE
  FORM
  PDF
  DESIGNER
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SectionType {
  HERO
  NORMAL
  CTA
  FOOTER
  FLEXIBLE
}

enum ElementType {
  TEXT
  HEADING
  PARAGRAPH
  IMAGE
  VIDEO
  ICON
  BUTTON
  LINK
  CONTAINER
  ROW
  COLUMN
  SPACER
  DIVIDER
  HTML
}

// ── Content Type Engine ──────────────────────────────────────────────────────

model ContentType {
  id               String         @id @default(cuid())
  slug             String         @unique
  name             String
  pluralName       String
  icon             String         @default("bi-collection")
  description      String?
  hasPublicListing Boolean        @default(true)
  hasPublicDetail  Boolean        @default(true)
  listingLayout    String         @default("grid")
  detailLayout     String         @default("standard")
  sortField        String         @default("publishedAt")
  sortDirection    String         @default("desc")
  enableComments   Boolean        @default(false)
  enableTags       Boolean        @default(true)
  fields           ContentField[]
  entries          ContentEntry[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("content_types")
}

model ContentField {
  id            String      @id @default(cuid())
  contentTypeId String
  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  fieldType     String
  required      Boolean     @default(false)
  defaultValue  String?
  options       Json?
  placeholder   String?
  helpText      String?
  sortOrder     Int         @default(0)
  validation    Json?

  @@unique([contentTypeId, slug])
  @@map("content_fields")
}

model ContentEntry {
  id            String                @id @default(cuid())
  contentTypeId String
  contentType   ContentType           @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  slug          String
  title         String
  data          Json
  status        String                @default("draft")
  publishedAt   DateTime?
  scheduledAt   DateTime?
  authorId      String
  author        User                  @relation(fields: [authorId], references: [id])
  tags          String[]              @default([])
  excerpt       String?
  coverImage    String?
  versions      ContentEntryVersion[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([contentTypeId, slug])
  @@index([contentTypeId, status])
  @@index([contentTypeId, publishedAt])
  @@map("content_entries")
}

model ContentEntryVersion {
  id          String       @id @default(cuid())
  entryId     String
  entry       ContentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  data        Json
  title       String
  createdAt   DateTime     @default(now())
  createdById String

  @@map("content_entry_versions")
}
